# Copy to .env.auth (gitignored) and fill in. Consumed by docker-compose.auth.yml via `make run`.
# These names are read directly by oauth2-proxy (OAUTH2_PROXY_* env convention).

# 1. Register a GitHub OAuth app: https://github.com/settings/developers
#      Homepage URL:               http://localhost:8000
#      Authorization callback URL: http://localhost:8000/oauth2/callback
#    Then copy the client id and a generated client secret here.
OAUTH2_PROXY_CLIENT_ID=your-github-oauth-app-client-id
OAUTH2_PROXY_CLIENT_SECRET=your-github-oauth-app-client-secret

# 2. Cookie secret — throwaway for local use. Must be 16, 24, or 32 bytes. Generate one with:
#      openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=generate-a-32-byte-base64-secret
